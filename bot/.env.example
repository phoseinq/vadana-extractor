# ---- Vadana bot configuration (copy to .env and fill in) --------------------

# Telegram bot token from @BotFather                         (required)
BOT_TOKEN=

# Proxy to reach the Iran-only Vadana host from a server abroad (recommended)
#   socks5://user:pass@IRAN_IP:1080   or   http://IRAN_IP:8080
IRAN_PROXY=

# Comma-separated Telegram user ids allowed to build videos   (optional)
ADMINS=

# Allow whiteboard -> video (heavy, admins only): 1 enable / 0 disable
ALLOW_VIDEO=0

# ---- tuning (optional, sensible defaults) -----------------------------------
MAX_CONCURRENT=3            # global parallel slide jobs
MAX_VIDEO_CONCURRENT=1      # parallel video builds (heavy)
MAX_VIDEO_PER_DAY=3         # per-user daily video builds
USER_COOLDOWN=15            # seconds between a user's jobs
MAX_UPLOAD_MB=1950          # skip files larger than this when sending

# Private channel id used as a file cache (bot must be admin there)  (optional)
STORAGE_CHANNEL=

# Local Telegram Bot API server for uploads up to 2 GB, e.g. http://127.0.0.1:8081
LOCAL_API_URL=

# Text shown in the bot's "Support" section                  (optional)
SUPPORT_TEXT=
