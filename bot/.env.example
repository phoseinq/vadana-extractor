# ---- Vadana bot configuration (copy to .env and fill in) --------------------

# Telegram bot token from @BotFather                          (required)
BOT_TOKEN=

# Proxy to reach the Iran-only Vadana host. ONLY for a server abroad —
# leave empty on a personal machine or an Iran server (direct access).
#   socks5://user:pass@IRAN_IP:1080   or   http://IRAN_IP:8080
IRAN_PROXY=

# Comma-separated Telegram user ids allowed to build videos   (optional)
ADMINS=

# Private channel id used as a file cache; the bot must be an admin there
STORAGE_CHANNEL=

# Allow whiteboard -> video (heavy, admins only): 1 enable / 0 disable
ALLOW_VIDEO=0

# Speech cleanup on the video's audio (denoise + level) is ON by default.
# Set a custom ffmpeg filter chain to tune it, or an empty value to turn it off:
#   AUDIO_DENOISE=                 # off
#   AUDIO_DENOISE=afftdn=nr=20     # stronger denoise

# ---- tuning (optional, sensible defaults) -----------------------------------
MAX_CONCURRENT=3
MAX_VIDEO_CONCURRENT=1
MAX_VIDEO_PER_DAY=3
USER_COOLDOWN=15
MAX_UPLOAD_MB=1950

# Local Telegram Bot API server for uploads up to 2 GB, e.g. http://127.0.0.1:8081
LOCAL_API_URL=

# Text shown in the bot's "Support" section                  (optional)
SUPPORT_TEXT=
